# ============================================================
# HaggleArena Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Server
PORT=3005
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://neondb_owner:npg_UJq7cunXL3HE@ep-wispy-sea-ae9k0nve-pooler.c-2.us-east-2.aws.neon.tech/neondb?sslmode=require"

